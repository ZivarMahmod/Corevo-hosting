{
  "$comment": "Corevo back-office — design tokens. Two CSS worlds that must NEVER mix. Back-office = Corevo forest/gold system look (scoped [data-world=backoffice]). Storefront = per-tenant salon theme (scoped [data-world=storefront][data-theme=...]). Customer portal lives in the storefront world (salvia theme), never Corevo green.",
  "backoffice": {
    "scope": "[data-world=\"backoffice\"]",
    "color": {
      "brand": {
        "forest": "#1F4636",
        "forest-700": "#173529",
        "forest-300": "#4E7363",
        "gold": "#F5A623",
        "gold-600": "#D98E12",
        "gold-100": "#FBEBCB"
      },
      "surface": {
        "cream": "#FAF8F4",
        "paper": "#FFFFFF",
        "paper-2": "#F3EFE8",
        "line": "#E7E1D6",
        "line-strong": "#D8D0C2"
      },
      "text": {
        "ink": "#21261F",
        "ink-2": "#555C50",
        "ink-3": "#8A8F82",
        "on-forest": "#EFEAE0",
        "on-forest-2": "#9DB1A6"
      },
      "status": {
        "success": "#4E7A5E", "success-bg": "#E8F0EA",
        "warning": "#A37D3C", "warning-bg": "#F3EBD9",
        "danger": "#9E5A57", "danger-bg": "#F1E2E0",
        "info": "#5E748C", "info-bg": "#E6EAF0"
      }
    },
    "typography": {
      "fontDisplay": "'Playfair Display', Georgia, serif",
      "fontUi": "'Inter', system-ui, -apple-system, sans-serif",
      "roles": {
        "h-display": { "family": "display", "weight": 700, "size": 40, "lineHeight": 1.08, "letterSpacing": "-0.02em", "color": "forest" },
        "h1": { "family": "display", "weight": 700, "size": 28, "lineHeight": 1.15, "color": "forest" },
        "h2": { "family": "ui", "weight": 600, "size": 19, "lineHeight": 1.25, "color": "ink" },
        "h3": { "family": "ui", "weight": 600, "size": 15, "lineHeight": 1.3, "color": "ink" },
        "eyebrow": { "family": "ui", "weight": 600, "size": 11, "letterSpacing": "0.18em", "transform": "uppercase", "color": "gold-600" },
        "body": { "size": 14, "lineHeight": 1.55, "color": "ink-2" },
        "small": { "size": 12.5, "lineHeight": 1.45, "color": "ink-3" },
        "num": { "note": "tabular-nums; font-feature-settings: 'tnum' — use for all times, counts, money, points" }
      }
    },
    "radius": { "xs": 4, "sm": 8, "md": 12, "card": 16, "lg": 18, "modal": 20, "xl": 28, "pill": 999 },
    "shadow": {
      "sm": "0 1px 2px rgba(31,70,54,.06), 0 1px 3px rgba(31,70,54,.08)",
      "md": "0 4px 14px rgba(31,70,54,.08), 0 2px 6px rgba(31,70,54,.06)",
      "lg": "0 18px 48px rgba(23,53,41,.16)"
    },
    "motion": {
      "ease-out": "cubic-bezier(0.22, 1, 0.36, 1)",
      "ease-in-out": "cubic-bezier(0.65, 0, 0.35, 1)",
      "dur-fast": "160ms", "dur-base": "280ms", "dur-slow": "520ms"
    }
  },
  "spacing": { "1": 4, "2": 8, "3": 12, "4": 16, "5": 24, "6": 32, "7": 48, "8": 64, "note": "8px base scale with editorial half-steps" },
  "storefront_salvia": {
    "$comment": "Customer portal theme (Studio Salvia). Sage/airy/minimal. NO Corevo green/gold here.",
    "scope": "[data-world=\"storefront\"][data-theme=\"salvia\"]",
    "color": {
      "primary": "#5E7361", "primary-d": "#44543F", "bg": "#F1EFE8", "surface": "#FFFFFF",
      "fg": "#232520", "fg-2": "#5C5F55", "line": "#E2DED2", "soft": "#EAEBE3", "gold": "#B08A4A"
    },
    "typography": {
      "fontDisplay": "'Cormorant Garamond', Georgia, serif",
      "fontBody": "'Jost', 'Inter', sans-serif",
      "radius": 10
    }
  },
  "storefront_themes": {
    "$comment": "5 onboarding templates. Each repaints the storefront via tokens. Full set used by ThemePreview + onboarding.",
    "Salvia": { "primary": "#5E7361", "bg": "#F6F4EE", "display": "Cormorant Garamond", "body": "Jost", "radius": 10, "vibe": "Lugn & minimal" },
    "Leander": { "primary": "#7E6E92", "bg": "#FBFAF8", "display": "Playfair Display", "body": "Inter", "radius": 14, "vibe": "Romantisk editorial" },
    "Zigge": { "primary": "#C8743C", "bg": "#14120E", "display": "Bebas Neue", "body": "Archivo", "radius": 4, "caps": true, "vibe": "Mörk & rå barber" },
    "Linnea": { "primary": "#B0693F", "bg": "#F4EDE1", "display": "DM Serif Display", "body": "Inter", "radius": 12, "vibe": "Varm skandinavisk" },
    "Edit": { "primary": "#3A3733", "bg": "#F8F6F1", "display": "Cormorant Garamond", "body": "Inter", "radius": 2, "vibe": "Elegant minimal" }
  }
}
