{
  "name": "@corevo/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "vakt": "node scripts/vakt-bransch.mjs",
    "kontrast": "node scripts/kontrast.mjs",
    "vakt:foton": "vitest run components/storefront/foton.test.tsx",
    "gen:theme-css": "node -e \"process.env.GEN='1';require('child_process').execSync('vitest run components/storefront/layouts/theme-css.sync.test.ts',{stdio:'inherit'})\"",
    "vakt:kontrast": "node scripts/vakt-kontrast.mjs",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "vitest run components/storefront/layouts/theme-css.sync.test.ts && opennextjs-cloudflare build && node scripts/deploy-prod.mjs"
  },
  "dependencies": {
    "@corevo/auth": "workspace:*",
    "@corevo/db": "workspace:*",
    "@corevo/ui": "workspace:*",
    "@supabase/ssr": "0.10.3",
    "@supabase/supabase-js": "2.106.2",
    "html-react-parser": "^6.1.3",
    "next": "15.5.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "0.0.1",
    "stripe": "22.2.0"
  },
  "devDependencies": {
    "@corevo/config": "workspace:*",
    "@opennextjs/cloudflare": "1.19.11",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.5.18",
    "happy-dom": "^20.10.6",
    "jsonc-parser": "^3.3.1",
    "tailwindcss": "4.3.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.0",
    "wrangler": "4.95.0"
  }
}
