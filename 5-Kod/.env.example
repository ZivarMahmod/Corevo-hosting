# ============================================================================
#  Corevo Booking Platform — environment template
#  Copy to apps/web/.env.local and fill in. .env*.local is gitignored.
# ============================================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Server-only. NEVER expose to the client. Used for admin / webhooks / platform_admin.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App / tenant resolution (ADR 01 §2) ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# localhost | live
NEXT_PUBLIC_TENANT_MODE=localhost
# dev: localhost:3000   |   live: corevo.se
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
NEXT_PUBLIC_PLATFORM_HOST=booking.corevo.se
# POS coexistence: superadmin/kiosk/dev/odoo are POS subdomains on corevo.se — reserve them too.
NEXT_PUBLIC_RESERVED_SUBDOMAINS=booking,admin,app,www,api,superadmin,kiosk,dev,odoo
# empty in dev | .corevo.se live (session shared across *.corevo.se subdomains)
AUTH_COOKIE_DOMAIN=

# ---- Platform / G08 ----
# HARD SPÄRR for customer-owned custom domains (CNAME / Cloudflare custom hostname).
# Tenants run ONLY on *.corevo.se subdomains. Keep this false — the platform domain
# UI is built but fires NO Cloudflare call. Flipping to true still requires manual ops.
DOMAIN_PROVISIONING_ENABLED=false

# ---- Cloudflare R2 (binding name = BUCKET) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=corevo-media

# ---- Stripe (placeholders — wired in G09) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
