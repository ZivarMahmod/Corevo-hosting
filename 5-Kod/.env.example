# ============================================================================
#  Corevo (multi-bransch-plattform) — environment template
#  Copy to apps/web/.env.local and fill in. .env*.local is gitignored.
# ============================================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Server-only. NEVER expose to the client. Used for admin / webhooks / platform_admin.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App / tenant resolution (ADR 01 §2) ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# dev: localhost:3000   |   live: corevo.se
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
NEXT_PUBLIC_PLATFORM_HOST=booking.corevo.se
# POS coexistence: superadmin/kiosk/dev/odoo are POS subdomains on corevo.se — reserve them too.
NEXT_PUBLIC_RESERVED_SUBDOMAINS=booking,admin,app,www,api,superadmin,kiosk,dev,odoo
# empty in dev | .corevo.se live (session shared across *.corevo.se subdomains)
AUTH_COOKIE_DOMAIN=

# ---- Platform / G08 ----
# HARD SPÄRR for customer-owned custom domains (CNAME / Cloudflare custom hostname).
# Tenants run ONLY on *.corevo.se subdomains. Keep this false — the platform domain
# UI is built but fires NO Cloudflare call. Flipping to true still requires manual ops.
DOMAIN_PROVISIONING_ENABLED=false

# ---- Cloudflare R2 (binding name = BUCKET; accessed via Workers binding, NOT S3 API) ----
R2_BUCKET_NAME=corevo-media
CLOUDFLARE_API_TOKEN=
# ---- Stripe (G09 — TEST-mode tills Zivar säger live) ----
# Connect Express + DIRECT charges, application_fee = 0. Empty → online-betalning
# degraderar tyst till "betala på plats" (build/lint/dev funkar utan nycklar).
# Set as Worker secrets in prod (like SUPABASE_SERVICE_ROLE_KEY).
STRIPE_SECRET_KEY=
# Connect-endpointens signing secret (events bär `account`). Webhook: /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# ---- Observability (goal-44 Spår A) — OPS-GATED, sätts som Worker-secret ----
# Sentry DSN för felrapportering. TOM → captureException loggar bara till Workers
# loggström (graceful degrade, kastar aldrig). Satt → POST:ar även ett minimalt
# Sentry-envelope server-side. Format: https://<publicKey>@<host>/<projectId>.
# Sätt ALDRIG i repo — bara som Cloudflare Worker-secret (som SUPABASE_SERVICE_ROLE_KEY).
SENTRY_DSN=

# ---- Giada SMS-gateway (server-only; PIN-bokning faller tillbaka till e-post) ----
GIADA_SMS_BASE_URL=https://sms.corevo.se
GIADA_SMS_API_KEY=
GIADA_HEALTH_MAX_AGE_SECONDS=90
GIADA_HEALTH_TIMEOUT_MS=1500
GIADA_SEND_TIMEOUT_MS=4000
# Minst 32 slumpmässiga tecken. Används endast server-side för HMAC av PIN/kontakt.
BOOKING_PIN_PEPPER=
